{
  "name": "zenymob2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:data": "node scripts/generate-data.mjs && node scripts/enrich-experience.mjs && node scripts/enrich-sprite-names.mjs",
    "sync:sprites": "node scripts/sync-monster-sprites.mjs",
    "build": "npm run generate:data && tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "wrangler deploy",
    "enrich:experience": "node scripts/enrich-experience.mjs",
    "enrich:sprite-names": "node scripts/enrich-sprite-names.mjs"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "wrangler": "4.105.0"
  }
}
